# Production Compose values. Copy to .env and replace every CHANGE_ME value.
SERVER_HOST=CHANGE_ME_PUBLIC_IP_OR_DOMAIN
LABOPS_VERSION=dev

MYSQL_ROOT_PASSWORD=CHANGE_ME_RANDOM_ROOT_PASSWORD
MYSQL_PASSWORD=CHANGE_ME_RANDOM_APP_PASSWORD
LABOPS_MYSQL_DSN=labops:CHANGE_ME_RANDOM_APP_PASSWORD@tcp(mysql:3306)/labops?parseTime=true&charset=utf8mb4

# Used only when the users table is empty, or to replace the legacy admin/admin password.
LABOPS_BOOTSTRAP_ADMIN_PASSWORD=CHANGE_ME_AT_LEAST_12_CHARACTERS

# Standard base64 encoding of 32 random bytes. PowerShell generation example:
# [Convert]::ToBase64String([Security.Cryptography.RandomNumberGenerator]::GetBytes(32))
LABOPS_ENCRYPTION_KEY=CHANGE_ME_BASE64_32_RANDOM_BYTES
