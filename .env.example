# LabOps 环境变量示例
# 复制此文件为 .env 并根据需要修改

# Server 监听地址
LABOPS_ADDR=:8080

# 数据库驱动: mysql (默认) 或 sqlite
LABOPS_DB_DRIVER=mysql

# SQLite 数据库文件路径 (仅 sqlite 驱动时使用)
# LABOPS_DB_PATH=data/labops.db

# MySQL 连接字符串 (需要先创建 labops 数据库)
LABOPS_MYSQL_DSN=root:123456@tcp(127.0.0.1:3307)/labops?parseTime=true&charset=utf8mb4

# Agent 认证 Token（Agent 连接 WebSocket 时需要）
LABOPS_AGENT_TOKEN=dev-agent-token

# Web 认证 Token（前端 REST API 调用时需要）
LABOPS_WEB_TOKEN=dev-token

# 心跳超时时间（默认 35s）
# LABOPS_HEARTBEAT_TIMEOUT=35s

# 任务超时时间（默认 2m）
# LABOPS_TASK_TIMEOUT=2m

# Vite 开发服务器代理目标（前端开发时使用）
VITE_PROXY_TARGET=http://localhost:8080

# API 基础 URL（前端构建时使用，默认 /api）
# VITE_API_BASE_URL=/api

# LLM / AI Ops 配置（可选，也可通过 Web UI 设置）
# 支持 OpenAI 兼容接口（DeepSeek、Ollama、vLLM 等）和 Anthropic 兼容接口
# LABOPS_LLM_URL=
# LABOPS_LLM_API_KEY=
